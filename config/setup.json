{
  "_comment": "Setup input. Run setup.bat/sh after editing. Paths here will be used to generate project-side config files and directory structure. Discard changes to this file after setup.",

  "projectRoot": ".",
  "projectConfigPath": "config/configtool.json",

  "excelPath": "excels/",
  "enumPath": "EnumTypes",
  "cleanBeforeGenerate": true,
  "outputPaths": {
    "json": "output/json/",
    "binary": "output/binary/",
    "code": "output/code/"
  },
  "generators": {
    "enableJson": true,
    "enableBinary": true,
    "enableCode": true
  },
  "codeGeneration": {
    "namespace": "GameData",
    "language": "csharp",
    "generateEnum": true
  },
  "validation": {
    "enableTypeCheck": true,
    "enforceNonNullableColumns": true
  }
}
