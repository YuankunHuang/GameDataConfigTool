{
  "excelPath": "excels/",
  "enumPath": "EnumTypes",
  "cleanBeforeGenerate": true,
  "outputPaths": {
    "json": "output/json/",
    "binary": "Assets/StreamingAssets/ConfigData/",
    "code": "Assets/Scripts/ConfigData/"
  },
  "generators": {
    "enableJson": false,
    "enableBinary": true,
    "enableCode": true
  },
  "codeGeneration": {
    "namespace": "GameData",
    "language": "csharp",
    "generateEnum": true
  },
  "validation": {
    "enableTypeCheck": true,
    "enforceNonNullableColumns": true
  }
}
